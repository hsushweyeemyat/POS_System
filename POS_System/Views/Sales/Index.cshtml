@using System.Text.Json
@model SalesIndexViewModel
@{
    ViewData["Title"] = "Dashboard";
    var jsonOptions = new JsonSerializerOptions(JsonSerializerDefaults.Web);
    var initialStateJson = JsonSerializer.Serialize(Model, jsonOptions);
}

<div class="page-shell sales-page-shell">
    <div id="sales-feedback" class="message-banner status-banner d-none" role="alert"></div>

    <section class="section-card sales-dashboard-hero">
        <div class="sales-dashboard-copy">
            <span class="sales-dashboard-kicker">Main Screen</span>
            <h2 class="section-title">Sales Dashboard</h2>
            <p class="section-description">Browse by category, tap products to add them, and complete checkout from one working surface.</p>
        </div>

        <div class="stats-row sales-summary-strip">
            <article class="stats-card">
                <span>Visible products</span>
                <strong id="sales-visible-products">@Model.ProductCount.ToString("N0")</strong>
                <small>Items shown for the current category and search.</small>
            </article>
            <article class="stats-card">
                <span>Items in cart</span>
                <strong id="sales-cart-quantity">@Model.Cart.TotalQuantity.ToString("N0")</strong>
                <small>Updated instantly as cashiers build the sale.</small>
            </article>
            <article class="stats-card">
                <span>Total payable</span>
                <strong id="sales-cart-total">MMK @Model.Cart.TotalAmount.ToString("N0")</strong>
                <small>Live total from the current cart contents.</small>
            </article>
        </div>
    </section>

    <div class="pos-grid sales-grid">
        <div class="pos-column">
            <section class="section-card sales-catalog-card">
                <div class="sales-catalog-head">
                    <div class="section-heading-copy">
                        <span id="sales-active-category-label" class="sales-kicker">All Items</span>
                        <h2 class="section-title">Product Browser</h2>
                        <p class="section-description">Tap a product card to add it directly into the cart.</p>
                    </div>

                    <label class="board-search sales-search-box" for="sales-search-input">
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <circle cx="11" cy="11" r="6"></circle>
                            <path d="M20 20L16.65 16.65"></path>
                        </svg>
                        <input id="sales-search-input" type="search" value="@Model.SearchTerm" placeholder="Search active products by name..." autocomplete="off" />
                    </label>
                </div>

                <div class="sales-catalog-meta">
                    <div id="sales-results-count" class="users-result-pill"><span>@Model.ProductCount.ToString("N0")</span> results</div>
                    <span class="sales-meta-copy">Live stock stays in sync, and category pills help cashiers browse faster.</span>
                </div>

                <div id="sales-category-strip" class="sales-category-strip" role="tablist" aria-label="Product categories"></div>

                <div id="sales-products" class="sales-product-grid"></div>

                <div id="sales-products-empty" class="empty-state sales-empty-state d-none">
                    <strong>No products found</strong>
                    <p>Try another keyword or switch back to All Items.</p>
                </div>
            </section>
        </div>

        <aside class="section-card invoice-panel sales-cart-card">
            <div class="section-heading">
                <div class="section-heading-copy">
                    <span class="sales-kicker">Current Cart</span>
                    <h2 class="section-title">Checkout Panel</h2>
                    <p class="section-description">Review items, adjust quantities, and complete the current sale.</p>
                </div>
                <span class="section-meta-pill">Session cart</span>
            </div>

            <div id="sales-cart-note" class="message-banner sales-cart-note d-none"></div>

            <div id="sales-cart-items" class="sales-cart-items"></div>

            <div id="sales-cart-empty" class="empty-state sales-empty-state d-none">
                <strong>Cart is empty</strong>
                <p>Select a product card to begin this sale.</p>
            </div>

            <div class="invoice-summary sales-cart-summary">
                <div class="invoice-summary-row">
                    <span>Total quantity</span>
                    <strong id="sales-summary-quantity">@Model.Cart.TotalQuantity.ToString("N0")</strong>
                </div>
                <div class="invoice-summary-row total">
                    <span>Total amount</span>
                    <strong id="sales-summary-total">MMK @Model.Cart.TotalAmount.ToString("N0")</strong>
                </div>
            </div>

            <button id="sales-checkout-button" type="button" class="btn btn-primary w-100 sales-checkout-button">
                Complete Sale
            </button>
        </aside>
    </div>

    <form id="sales-antiforgery" class="d-none">
        @Html.AntiForgeryToken()
    </form>
</div>

<script id="sales-initial-state" type="application/json">@Html.Raw(initialStateJson)</script>

@section Scripts {
    <script>
        (() => {
            const initialStateElement = document.getElementById('sales-initial-state');
            const feedbackElement = document.getElementById('sales-feedback');
            const categoryStripElement = document.getElementById('sales-category-strip');
            const activeCategoryLabelElement = document.getElementById('sales-active-category-label');
            const productsElement = document.getElementById('sales-products');
            const productsEmptyElement = document.getElementById('sales-products-empty');
            const cartItemsElement = document.getElementById('sales-cart-items');
            const cartEmptyElement = document.getElementById('sales-cart-empty');
            const cartNoteElement = document.getElementById('sales-cart-note');
            const searchInput = document.getElementById('sales-search-input');
            const resultsCountElement = document.getElementById('sales-results-count');
            const checkoutButton = document.getElementById('sales-checkout-button');
            const visibleProductsMetric = document.getElementById('sales-visible-products');
            const cartQuantityMetric = document.getElementById('sales-cart-quantity');
            const cartTotalMetric = document.getElementById('sales-cart-total');
            const summaryQuantityElement = document.getElementById('sales-summary-quantity');
            const summaryTotalElement = document.getElementById('sales-summary-total');
            const antiForgeryToken = document.querySelector('#sales-antiforgery input[name="__RequestVerificationToken"]')?.value ?? '';
            const endpoints = {
                state: '@Url.Action("State", "Sales")',
                add: '@Url.Action("AddToCart", "Sales")',
                update: '@Url.Action("UpdateQuantity", "Sales")',
                remove: '@Url.Action("RemoveItem", "Sales")',
                checkout: '@Url.Action("Checkout", "Sales")'
            };

            let state = normalizeState(JSON.parse(initialStateElement.textContent ?? '{}'));
            let activeCategory = 'all';
            let searchDebounceHandle = 0;
            let requestVersion = 0;

            const numberFormatter = new Intl.NumberFormat();
            const mediaToneClasses = ['media-tilapia', 'media-boba', 'media-rice', 'media-lemon', 'media-dimsum', 'media-latte'];
            const preferredCategoryOrder = ['electronics', 'clothing', 'food & beverage', 'home & garden', 'sports'];
            const stockIconMarkup = `
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M6 8.5H18" />
                    <path d="M7 8.5V18.5H17V8.5" />
                    <path d="M9 8.5V6.5C9 5.67 9.67 5 10.5 5H13.5C14.33 5 15 5.67 15 6.5V8.5" />
                </svg>
            `;

            function normalizeState(rawState) {
                return {
                    searchTerm: rawState?.searchTerm ?? '',
                    productCount: rawState?.productCount ?? 0,
                    products: Array.isArray(rawState?.products) ? rawState.products : [],
                    cart: {
                        items: Array.isArray(rawState?.cart?.items) ? rawState.cart.items : [],
                        totalQuantity: rawState?.cart?.totalQuantity ?? 0,
                        totalAmount: rawState?.cart?.totalAmount ?? 0,
                        canCheckout: !!rawState?.cart?.canCheckout,
                        validationMessage: rawState?.cart?.validationMessage ?? ''
                    }
                };
            }

            function formatNumber(value) {
                return numberFormatter.format(value ?? 0);
            }

            function formatCurrency(value) {
                return `MMK ${formatNumber(value)}`;
            }

            function escapeHtml(value) {
                return String(value ?? '')
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#39;');
            }

            function buildToken(value) {
                const words = String(value ?? '')
                    .split(/\s+/)
                    .filter(Boolean)
                    .slice(0, 2);
                const token = words.map(word => word[0]?.toUpperCase() ?? '').join('');
                return token || 'IT';
            }

            function normalizeCategoryKey(value) {
                return String(value ?? '').trim().toLowerCase();
            }

            function buildCategories(products) {
                const categoryMap = new Map();

                products.forEach(product => {
                    const label = String(product.categoryName ?? '').trim() || 'Uncategorized';
                    const key = normalizeCategoryKey(label);

                    if (!categoryMap.has(key)) {
                        categoryMap.set(key, { key, label, count: 0 });
                    }

                    categoryMap.get(key).count += 1;
                });

                const categories = Array.from(categoryMap.values()).sort((left, right) => {
                    const leftIndex = preferredCategoryOrder.indexOf(left.key);
                    const rightIndex = preferredCategoryOrder.indexOf(right.key);

                    if (leftIndex !== -1 || rightIndex !== -1) {
                        return (leftIndex === -1 ? Number.MAX_SAFE_INTEGER : leftIndex)
                            - (rightIndex === -1 ? Number.MAX_SAFE_INTEGER : rightIndex);
                    }

                    return left.label.localeCompare(right.label);
                });

                return [{
                    key: 'all',
                    label: 'All Items',
                    count: products.length
                }, ...categories];
            }

            function getCategories() {
                return buildCategories(state.products);
            }

            function ensureActiveCategory() {
                const categories = getCategories();

                if (!categories.some(category => category.key === activeCategory)) {
                    activeCategory = 'all';
                }

                return categories;
            }

            function getVisibleProducts() {
                if (activeCategory === 'all') {
                    return state.products;
                }

                return state.products.filter(product => normalizeCategoryKey(product.categoryName) === activeCategory);
            }

            function pickToneClass(seed) {
                const text = String(seed ?? '');
                let hash = 0;

                for (const character of text) {
                    hash = ((hash << 5) - hash) + character.charCodeAt(0);
                    hash |= 0;
                }

                return mediaToneClasses[Math.abs(hash) % mediaToneClasses.length];
            }

            function categoryClass(categoryName) {
                const label = normalizeCategoryKey(categoryName);
                return label.includes('drink') || label.includes('tea') || label.includes('coffee') || label.includes('beverage')
                    ? 'tag-beverage'
                    : 'tag-food';
            }

            function renderProductIcon(content) {
                return `
                    <svg viewBox="0 0 140 140" class="sales-product-icon" aria-hidden="true" focusable="false">
                        ${content}
                    </svg>
                `;
            }

            function productToneClass(product) {
                return pickToneClass(`${product?.categoryName ?? ''}-${product?.name ?? ''}`);
            }

            function productIllustration(product) {
                const name = normalizeCategoryKey(product?.name);
                const category = normalizeCategoryKey(product?.categoryName);

                if (name.includes('headphone') || name.includes('headset')) {
                    return renderProductIcon(`
                        <path d="M44 79V69C44 48 60 32 80 32C100 32 116 48 116 69V79" fill="none" stroke="#94a3b8" stroke-width="8" />
                        <rect x="35" y="76" width="18" height="34" rx="9" fill="#cbd5e1" />
                        <rect x="107" y="76" width="18" height="34" rx="9" fill="#cbd5e1" />
                        <path d="M53 92C53 82 61 74 71 74" fill="none" stroke="#e2e8f0" stroke-width="7" />
                        <path d="M107 92C107 82 99 74 89 74" fill="none" stroke="#e2e8f0" stroke-width="7" />
                    `);
                }

                if (name.includes('mug') || name.includes('coffee')) {
                    return renderProductIcon(`
                        <path d="M50 58H90C99 58 106 65 106 74V92C106 104 96 114 84 114H56C44 114 34 104 34 92V74C34 65 41 58 50 58Z" fill="#b9a7d8" />
                        <path d="M106 72H111C118 72 124 78 124 85C124 92 118 98 111 98H104" fill="none" stroke="#8f7ab8" stroke-width="7" />
                        <path d="M56 45C56 40 59 36 63 33" fill="none" stroke="#e8def9" stroke-width="6" />
                        <path d="M73 45C73 40 76 36 80 33" fill="none" stroke="#e8def9" stroke-width="6" />
                        <path d="M47 80H94" fill="none" stroke="#e7ddf7" stroke-width="7" />
                    `);
                }

                if (name.includes('cable') || name.includes('usb') || name.includes('charger')) {
                    return renderProductIcon(`
                        <path d="M70 38V80" fill="none" stroke="#475569" stroke-width="8" />
                        <rect x="58" y="80" width="24" height="30" rx="8" fill="#384152" />
                        <rect x="59" y="56" width="22" height="23" rx="8" fill="#5b4682" />
                        <path d="M62 34V48" fill="none" stroke="#d5a267" stroke-width="6" />
                        <path d="M78 34V48" fill="none" stroke="#d5a267" stroke-width="6" />
                        <path d="M59 68H81" fill="none" stroke="#8f79bb" stroke-width="6" />
                    `);
                }

                if (name.includes('shirt') || name.includes('tee')) {
                    return renderProductIcon(`
                        <path d="M46 55L63 43H77L94 55L106 74L92 82V108H48V82L34 74Z" fill="#8fd26d" />
                        <path d="M63 43C64 49 69 53 76 53C83 53 88 49 89 43" fill="#d9de67" />
                        <path d="M61 59H79" fill="none" stroke="#7ac45d" stroke-width="7" />
                    `);
                }

                if (name.includes('sneaker') || name.includes('shoe')) {
                    return renderProductIcon(`
                        <path d="M35 88C47 86 57 79 65 67L84 80C92 86 101 91 111 93L119 95C122 96 124 99 124 103C124 108 120 111 114 111H52C42 111 34 103 34 94C34 91 34 89 35 88Z" fill="#ccb5f1" />
                        <path d="M62 72L75 82" fill="none" stroke="#8f79bb" stroke-width="6" />
                        <path d="M71 67L83 76" fill="none" stroke="#8f79bb" stroke-width="6" />
                        <path d="M51 99H115" fill="none" stroke="#f5edff" stroke-width="7" />
                    `);
                }

                if (name.includes('speaker')) {
                    return renderProductIcon(`
                        <rect x="46" y="35" width="48" height="78" rx="16" fill="#a6b7ff" />
                        <circle cx="70" cy="64" r="12" fill="#eff4ff" />
                        <circle cx="70" cy="90" r="17" fill="#6d85df" />
                        <circle cx="70" cy="90" r="6" fill="#eff4ff" />
                    `);
                }

                if (name.includes('mouse')) {
                    return renderProductIcon(`
                        <rect x="50" y="30" width="40" height="82" rx="20" fill="#d7dde8" />
                        <path d="M70 31V58" fill="none" stroke="#7c8799" stroke-width="7" />
                        <circle cx="70" cy="78" r="4" fill="#7c8799" />
                    `);
                }

                if (name.includes('notebook')) {
                    return renderProductIcon(`
                        <rect x="44" y="32" width="54" height="78" rx="12" fill="#9fc3ff" />
                        <rect x="98" y="32" width="8" height="78" rx="4" fill="#5f86d7" />
                        <path d="M58 55H82" fill="none" stroke="#eef4ff" stroke-width="7" />
                        <path d="M58 73H82" fill="none" stroke="#eef4ff" stroke-width="7" />
                        <path d="M58 91H74" fill="none" stroke="#eef4ff" stroke-width="7" />
                    `);
                }

                if (name.includes('snack') || name.includes('bar')) {
                    return renderProductIcon(`
                        <path d="M42 74L58 56H104L88 84H42Z" fill="#8b5a39" />
                        <path d="M36 68L52 50H68L52 68H36Z" fill="#f5c98c" />
                        <path d="M88 84L104 56H118L102 84H88Z" fill="#f5c98c" />
                    `);
                }

                if (name.includes('drink') || name.includes('bottle')) {
                    return renderProductIcon(`
                        <path d="M59 32H85V46" fill="none" stroke="#ef476f" stroke-width="6" />
                        <path d="M84 46H96" fill="none" stroke="#ef476f" stroke-width="6" />
                        <path d="M49 52H96L90 110H55Z" fill="#d5b2ec" />
                        <path d="M53 55H92V77H51Z" fill="#f33672" opacity="0.92" />
                        <path d="M58 81H88" fill="none" stroke="#fff5fb" stroke-width="7" />
                    `);
                }

                if (category.includes('electronics')) {
                    return renderProductIcon(`
                        <rect x="34" y="40" width="72" height="46" rx="12" fill="#a8bdf8" />
                        <path d="M60 102H98" fill="none" stroke="#6a84d9" stroke-width="7" />
                        <path d="M70 86V102" fill="none" stroke="#6a84d9" stroke-width="7" />
                    `);
                }

                if (category.includes('clothing')) {
                    return renderProductIcon(`
                        <path d="M48 56L64 43H78L94 56L104 74L91 82V108H51V82L38 74Z" fill="#97d27a" />
                        <path d="M64 43C65 48 70 51 76 51C82 51 87 48 88 43" fill="#d9de67" />
                    `);
                }

                if (category.includes('food') || category.includes('beverage')) {
                    return renderProductIcon(`
                        <path d="M52 54H92C100 54 106 60 106 68V96C106 106 98 114 88 114H56C46 114 38 106 38 96V68C38 60 44 54 52 54Z" fill="#c4afe1" />
                        <path d="M106 68H112C118 68 123 73 123 80C123 87 118 92 112 92H105" fill="none" stroke="#8f79bb" stroke-width="7" />
                    `);
                }

                if (category.includes('sports')) {
                    return renderProductIcon(`
                        <circle cx="74" cy="76" r="28" fill="#ffd08a" />
                        <path d="M74 48C81 57 87 67 90 76C87 85 81 95 74 104" fill="none" stroke="#c9843e" stroke-width="7" />
                        <path d="M46 76H102" fill="none" stroke="#c9843e" stroke-width="7" />
                    `);
                }

                if (category.includes('home')) {
                    return renderProductIcon(`
                        <path d="M44 72L74 46L104 72V108H44Z" fill="#a7c6f5" />
                        <path d="M60 108V82H88V108" fill="#eff5ff" />
                        <path d="M38 74L74 42L110 74" fill="none" stroke="#6f93da" stroke-width="7" />
                    `);
                }

                return renderProductIcon(`
                    <path d="M74 34L106 52V88L74 106L42 88V52Z" fill="#cbd5e1" />
                    <path d="M74 34V68L106 52" fill="none" stroke="#94a3b8" stroke-width="7" />
                    <path d="M74 68L42 52" fill="none" stroke="#94a3b8" stroke-width="7" />
                `);
            }

            function productGlyph(product) {
                const name = normalizeCategoryKey(product?.name);
                const category = normalizeCategoryKey(product?.categoryName);

                if (name.includes('headphone') || name.includes('headset')) return '🎧';
                if (name.includes('mug') || name.includes('coffee')) return '☕';
                if (name.includes('cable') || name.includes('usb') || name.includes('charger')) return '🔌';
                if (name.includes('shirt') || name.includes('tee')) return '👕';
                if (name.includes('sneaker') || name.includes('shoe')) return '👟';
                if (name.includes('speaker')) return '🔊';
                if (name.includes('yoga')) return '🧘';
                if (name.includes('bottle')) return '💧';
                if (name.includes('notebook')) return '📓';
                if (name.includes('mouse')) return '🖱️';
                if (name.includes('snack') || name.includes('bar')) return '🍫';
                if (name.includes('drink')) return '🥤';
                if (category.includes('electronics')) return '💻';
                if (category.includes('clothing')) return '🧥';
                if (category.includes('sports')) return '🏃';
                if (category.includes('home')) return '🏠';
                return '📦';
            }

            function setFeedback(message, type) {
                if (!message) {
                    feedbackElement.className = 'message-banner status-banner d-none';
                    feedbackElement.textContent = '';
                    return;
                }

                feedbackElement.className = `message-banner status-banner ${type === 'error' ? 'is-error' : 'is-success'}`;
                feedbackElement.textContent = message;
            }

            function renderCategoryStrip() {
                const categories = ensureActiveCategory();
                const activeCategoryLabel = categories.find(category => category.key === activeCategory)?.label ?? 'All Items';
                activeCategoryLabelElement.textContent = activeCategoryLabel;

                categoryStripElement.innerHTML = categories.map(category => `
                    <button
                        type="button"
                        class="sales-category-pill ${category.key === activeCategory ? 'active' : ''}"
                        data-category-key="${escapeHtml(category.key)}"
                        role="tab"
                        aria-selected="${category.key === activeCategory ? 'true' : 'false'}">
                        <span>${escapeHtml(category.label)}</span>
                    </button>
                `).join('');
            }

            function renderProducts() {
                const visibleProducts = getVisibleProducts();

                if (visibleProducts.length === 0) {
                    productsElement.innerHTML = '';
                    productsEmptyElement.classList.remove('d-none');
                    return;
                }

                productsEmptyElement.classList.add('d-none');
                productsElement.innerHTML = visibleProducts.map(product => {
                    const addDisabled = product.canAddMore ? '' : 'disabled';
                    const toneClass = productToneClass(product);
                    const inCartBadge = product.quantityInCart > 0
                        ? `<span class="sales-product-badge">In cart ${formatNumber(product.quantityInCart)}</span>`
                        : '';

                    return `
                        <button
                            type="button"
                            class="sales-product-card"
                            data-add-product="${product.id}"
                            aria-label="Add ${escapeHtml(product.name)}"
                            ${addDisabled}>
                            <div class="sales-product-media ${toneClass}">
                                ${inCartBadge}
                                <div class="sales-product-symbol" aria-hidden="true">${productIllustration(product)}</div>
                            </div>
                            <div class="sales-product-copy">
                                <h3 class="sales-product-name">${escapeHtml(product.name)}</h3>
                                <strong class="sales-product-price">${formatCurrency(product.price)}</strong>
                                <span class="sales-stock-pill">
                                    ${stockIconMarkup}
                                    <span>${formatNumber(product.stockQty)} in stock</span>
                                </span>
                            </div>
                        </button>
                    `;
                }).join('');
            }

            function renderCart() {
                const hasItems = state.cart.items.length > 0;

                cartEmptyElement.classList.toggle('d-none', hasItems);
                cartItemsElement.innerHTML = hasItems
                    ? state.cart.items.map(item => {
                        const toneClass = pickToneClass(`${item.productName}-${item.categoryName}`);
                        const token = buildToken(item.productName);
                        const minusDisabled = item.quantity <= 1 ? 'disabled' : '';
                        const plusDisabled = item.canIncreaseQuantity ? '' : 'disabled';
                        const unavailableClass = item.isAvailable ? '' : ' sales-cart-item-unavailable';
                        const categoryMarkup = item.categoryName
                            ? `<span class="sales-card-category ${categoryClass(item.categoryName)}">${escapeHtml(item.categoryName)}</span>`
                            : '';
                        const validationMarkup = item.validationMessage
                            ? `<p class="sales-cart-validation">${escapeHtml(item.validationMessage)}</p>`
                            : '';

                        return `
                            <article class="invoice-item sales-cart-item${unavailableClass}">
                                <div class="invoice-thumb ${toneClass}">
                                    <span>${token}</span>
                                </div>
                                <div class="invoice-item-main">
                                    <div class="invoice-item-head">
                                        <div class="sales-cart-copy">
                                            ${categoryMarkup}
                                            <strong>${escapeHtml(item.productName)}</strong>
                                            <p class="sales-cart-line-copy">Unit price ${formatCurrency(item.unitPrice)}</p>
                                        </div>
                                        <button type="button" class="sales-remove-button" data-remove-product="${item.productId}" aria-label="Remove ${escapeHtml(item.productName)}">
                                            Remove
                                        </button>
                                    </div>
                                    <div class="sales-cart-item-footer">
                                        <div class="quantity-pill sales-quantity-controls">
                                            <button type="button" class="circle-button sales-quantity-button" data-cart-decrease="${item.productId}" ${minusDisabled}>-</button>
                                            <span>${formatNumber(item.quantity)}</span>
                                            <button type="button" class="circle-button primary sales-quantity-button" data-cart-increase="${item.productId}" ${plusDisabled}>+</button>
                                        </div>
                                        <div class="sales-cart-line-values">
                                            <span>Subtotal</span>
                                            <strong>${formatCurrency(item.subtotal)}</strong>
                                        </div>
                                    </div>
                                    ${validationMarkup}
                                </div>
                            </article>
                        `;
                    }).join('')
                    : '';

                const showCartNote = !!state.cart.validationMessage && state.cart.items.length > 0;
                cartNoteElement.classList.toggle('d-none', !showCartNote);
                cartNoteElement.className = showCartNote
                    ? `message-banner sales-cart-note ${state.cart.canCheckout ? 'status-banner is-success' : 'status-banner is-error'}`
                    : 'message-banner sales-cart-note d-none';
                cartNoteElement.textContent = showCartNote ? state.cart.validationMessage : '';

                checkoutButton.disabled = !state.cart.canCheckout;
            }

            function renderMetrics() {
                const visibleCount = getVisibleProducts().length;
                resultsCountElement.innerHTML = `<span>${formatNumber(visibleCount)}</span> results`;
                visibleProductsMetric.textContent = formatNumber(visibleCount);
                cartQuantityMetric.textContent = formatNumber(state.cart.totalQuantity);
                cartTotalMetric.textContent = formatCurrency(state.cart.totalAmount);
                summaryQuantityElement.textContent = formatNumber(state.cart.totalQuantity);
                summaryTotalElement.textContent = formatCurrency(state.cart.totalAmount);
            }

            function renderState() {
                searchInput.value = state.searchTerm;
                renderCategoryStrip();
                renderProducts();
                renderCart();
                renderMetrics();
            }

            async function loadState(searchTerm) {
                const currentRequest = ++requestVersion;

                try {
                    const response = await fetch(`${endpoints.state}?searchTerm=${encodeURIComponent(searchTerm ?? '')}`, {
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!response.ok) {
                        throw new Error('Unable to load products.');
                    }

                    const responseState = normalizeState(await response.json());

                    if (currentRequest !== requestVersion) {
                        return;
                    }

                    state = responseState;
                    renderState();
                } catch (error) {
                    setFeedback('Unable to refresh product search right now.', 'error');
                }
            }

            async function postAction(url, payload) {
                requestVersion++;

                const formData = new URLSearchParams({
                    ...payload,
                    __RequestVerificationToken: antiForgeryToken
                });

                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: formData
                });

                if (!response.ok) {
                    throw new Error('Request failed.');
                }

                return await response.json();
            }

            searchInput.addEventListener('input', () => {
                window.clearTimeout(searchDebounceHandle);
                setFeedback('', 'success');
                searchDebounceHandle = window.setTimeout(() => {
                    loadState(searchInput.value.trim());
                }, 250);
            });

            searchInput.addEventListener('search', () => {
                window.clearTimeout(searchDebounceHandle);
                loadState(searchInput.value.trim());
            });

            searchInput.addEventListener('keydown', event => {
                if (event.key !== 'Enter') {
                    return;
                }

                event.preventDefault();
                window.clearTimeout(searchDebounceHandle);
                loadState(searchInput.value.trim());
            });

            categoryStripElement.addEventListener('click', event => {
                const categoryButton = event.target.closest('[data-category-key]');

                if (!categoryButton) {
                    return;
                }

                activeCategory = categoryButton.getAttribute('data-category-key') ?? 'all';
                renderState();
            });

            productsElement.addEventListener('click', async event => {
                const addButton = event.target.closest('[data-add-product]');

                if (!addButton) {
                    return;
                }

                try {
                    const result = await postAction(endpoints.add, {
                        productId: addButton.getAttribute('data-add-product') ?? '',
                        quantity: '1',
                        searchTerm: state.searchTerm
                    });

                    state = normalizeState(result.state);
                    renderState();
                    setFeedback(result.message, result.succeeded ? 'success' : 'error');
                } catch (error) {
                    setFeedback('Unable to add that product right now.', 'error');
                }
            });

            cartItemsElement.addEventListener('click', async event => {
                const removeButton = event.target.closest('[data-remove-product]');
                const increaseButton = event.target.closest('[data-cart-increase]');
                const decreaseButton = event.target.closest('[data-cart-decrease]');

                try {
                    if (removeButton) {
                        const result = await postAction(endpoints.remove, {
                            productId: removeButton.getAttribute('data-remove-product') ?? '',
                            searchTerm: state.searchTerm
                        });

                        state = normalizeState(result.state);
                        renderState();
                        setFeedback(result.message, result.succeeded ? 'success' : 'error');
                        return;
                    }

                    if (increaseButton || decreaseButton) {
                        const productId = increaseButton?.getAttribute('data-cart-increase')
                            ?? decreaseButton?.getAttribute('data-cart-decrease')
                            ?? '';
                        const cartItem = state.cart.items.find(item => String(item.productId) === String(productId));

                        if (!cartItem) {
                            return;
                        }

                        const nextQuantity = increaseButton
                            ? cartItem.quantity + 1
                            : cartItem.quantity - 1;

                        if (nextQuantity < 1) {
                            return;
                        }

                        const result = await postAction(endpoints.update, {
                            productId,
                            quantity: String(nextQuantity),
                            searchTerm: state.searchTerm
                        });

                        state = normalizeState(result.state);
                        renderState();
                        setFeedback(result.message, result.succeeded ? 'success' : 'error');
                    }
                } catch (error) {
                    setFeedback('Unable to update the cart right now.', 'error');
                }
            });

            checkoutButton.addEventListener('click', async () => {
                if (!state.cart.canCheckout) {
                    setFeedback(state.cart.validationMessage || 'Checkout is not available for this cart yet.', 'error');
                    return;
                }

                checkoutButton.disabled = true;
                checkoutButton.textContent = 'Processing...';

                try {
                    const result = await postAction(endpoints.checkout, {
                        searchTerm: state.searchTerm
                    });

                    if (!result.succeeded) {
                        state = normalizeState(result.state);
                        renderState();
                        setFeedback(result.message, 'error');
                        return;
                    }

                    if (result.redirectUrl) {
                        window.location.assign(result.redirectUrl);
                    }
                } catch (error) {
                    setFeedback('Unable to complete checkout right now.', 'error');
                } finally {
                    checkoutButton.textContent = 'Complete Sale';
                    checkoutButton.disabled = !state.cart.canCheckout;
                }
            });

            renderState();
        })();
    </script>
}
