@{
    ViewData["Title"] = "Access Denied";
}

<section class="status-page">
    <div class="section-card">
        <div class="error-code">Restricted Route</div>
        <div class="board-heading">
            <h2>Access denied</h2>
            <p>Your account is signed in, but this lane is reserved for another role.</p>
        </div>
        <p class="status-copy">
            Return to the orders board or move into the shared kitchen queue instead. The refreshed service-console shell keeps the interruption calm and consistent with the rest of the app.
        </p>

        <div class="status-actions">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Back to orders</a>
            <a asp-controller="Sales" asp-action="Index" class="btn btn-outline-secondary">Open POS sales</a>
        </div>
    </div>
</section>
