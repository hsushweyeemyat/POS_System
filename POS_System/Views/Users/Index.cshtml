@model UsersIndexViewModel
@{
    ViewData["Title"] = "Users";
    var statusMessage = TempData["StatusMessage"]?.ToString();
    var statusType = TempData["StatusType"]?.ToString() ?? "success";
    var hasUsers = Model.UsersPage.Items.Count > 0;
    var currentPageLabel = Model.UsersPage.TotalCount == 0 ? "0" : Model.UsersPage.Page.ToString();
    var pageSummary = Model.UsersPage.TotalCount == 0
        ? "Page 0 of 0"
        : $"Page {Model.UsersPage.Page} of {Model.UsersPage.TotalPages}";
}

<div class="page-shell">
    <section class="users-toolbar">
        <div class="board-heading">
            <h2>Users</h2>
            <p>Manage application users with add, edit, and delete actions from one searchable table.</p>
        </div>

        <button type="button" class="btn btn-primary users-add-button" data-bs-toggle="modal" data-bs-target="#createUserModal">
            <span>+</span>
            <span>Add User</span>
        </button>
    </section>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="message-banner status-banner @(string.Equals(statusType, "error", StringComparison.OrdinalIgnoreCase) ? "is-error" : "is-success")" role="alert">
            @statusMessage
        </div>
    }

    <section class="users-table-controls">
        <form asp-action="Index" method="get" class="users-search-form">
            <label class="users-search" for="users-table-search">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <circle cx="11" cy="11" r="6"></circle>
                    <path d="M20 20L16.65 16.65"></path>
                </svg>
                <input id="users-table-search" name="SearchTerm" type="search" value="@Model.Query.SearchTerm" placeholder="Search anything..." autocomplete="off" />
            </label>
            <input type="hidden" name="Page" value="1" />
            <input type="hidden" name="PageSize" value="@Model.Query.PageSize" />
        </form>

        <div class="users-result-pill">
            <span>@Model.UsersPage.TotalCount</span> results
        </div>
    </section>

    <section class="users-table-card">
        <div class="table-responsive @(hasUsers ? string.Empty : "d-none")">
            <table class="table users-table align-middle mb-0" id="users-data-table">
                <thead>
                    <tr>
                        <th>No.</th>
                        <th>FullName</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th class="users-action-column">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var userEntry in Model.UsersPage.Items.Select((user, index) => new { user, index }))
                    {
                        var user = userEntry.user;
                        var roleClass = string.Equals(user.Role, "Admin", StringComparison.OrdinalIgnoreCase)
                            ? "role-pill role-pill-admin"
                            : "role-pill role-pill-cashier";
                        var rowNumber = Model.UsersPage.FirstItemNumber + userEntry.index;

                        <tr>
                            <td>@rowNumber</td>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td>
                                <span class="@roleClass">@user.Role</span>
                            </td>
                            <td>
                                <div class="users-action-group">
                                    <button type="button" class="table-action" data-user-edit data-user-id="@user.Id" aria-label="Edit @user.FullName">
                                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                            <path d="M4 20H8L18 10C18.53 9.47 18.53 8.53 18 8L16 6C15.47 5.47 14.53 5.47 14 6L4 16V20Z"></path>
                                            <path d="M13 7L17 11"></path>
                                        </svg>
                                    </button>
                                    <button type="button" class="table-action table-action-danger" data-user-delete data-user-id="@user.Id" data-user-name="@user.FullName" aria-label="Delete @user.FullName">
                                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                            <path d="M5 7H19"></path>
                                            <path d="M9 7V5.5C9 4.67 9.67 4 10.5 4H13.5C14.33 4 15 4.67 15 5.5V7"></path>
                                            <path d="M8 10V17"></path>
                                            <path d="M12 10V17"></path>
                                            <path d="M16 10V17"></path>
                                            <path d="M6 7L7 19C7.07 19.78 7.72 20.38 8.5 20.38H15.5C16.28 20.38 16.93 19.78 17 19L18 7"></path>
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div id="users-empty-state" class="empty-state users-empty-state @(hasUsers ? "d-none" : string.Empty)">
            <strong>No users found</strong>
            <p>Try another search keyword or add a new user.</p>
        </div>
    </section>

    <section class="datatable-footer">
        <div class="datatable-summary-group">
            <span id="users-page-summary">@pageSummary</span>

            <form asp-action="Index" method="get" class="page-size-form">
                <input type="hidden" name="Page" value="1" />
                <input type="hidden" name="SearchTerm" value="@Model.Query.SearchTerm" />
                <label class="page-size-label" for="users-page-size">Rows</label>
                <div class="page-size-select-wrap">
                    <select id="users-page-size" name="PageSize" class="form-select page-size-select">
                        @foreach (var size in new[] { 5, 10, 25, 50 })
                        {
                            if (Model.Query.PageSize == size)
                            {
                                <option value="@size" selected>@size</option>
                            }
                            else
                            {
                                <option value="@size">@size</option>
                            }
                        }
                    </select>
                </div>
            </form>
        </div>

        <div class="pagination-controls">
            @if (Model.UsersPage.HasPreviousPage)
            {
                <a class="page-button"
                   asp-action="Index"
                   asp-route-page="@(Model.UsersPage.Page - 1)"
                   asp-route-pageSize="@Model.Query.PageSize"
                   asp-route-searchTerm="@Model.Query.SearchTerm"
                   aria-label="Previous page">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M14 6L8 12L14 18"></path>
                    </svg>
                </a>
            }
            else
            {
                <span class="page-button disabled" aria-disabled="true">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M14 6L8 12L14 18"></path>
                    </svg>
                </span>
            }

            <span class="page-button active">@currentPageLabel</span>

            @if (Model.UsersPage.HasNextPage)
            {
                <a class="page-button"
                   asp-action="Index"
                   asp-route-page="@(Model.UsersPage.Page + 1)"
                   asp-route-pageSize="@Model.Query.PageSize"
                   asp-route-searchTerm="@Model.Query.SearchTerm"
                   aria-label="Next page">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M10 6L16 12L10 18"></path>
                    </svg>
                </a>
            }
            else
            {
                <span class="page-button disabled" aria-disabled="true">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M10 6L16 12L10 18"></path>
                    </svg>
                </span>
            }
        </div>
    </section>
</div>

<div class="modal fade" id="createUserModal" tabindex="-1" aria-labelledby="createUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content user-modal">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Page" value="@Model.Query.Page" />
                <input type="hidden" name="PageSize" value="@Model.Query.PageSize" />
                <input type="hidden" name="SearchTerm" value="@Model.Query.SearchTerm" />

                <div class="modal-header user-modal-header">
                    <div>
                        <h3 class="modal-title" id="createUserModalLabel">Add User</h3>
                        <p class="user-modal-subtitle">Create a new Admin or Cashier account.</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body user-modal-body">
                    <div asp-validation-summary="ModelOnly" class="message-banner user-validation-summary text-danger"></div>
                    <input asp-for="CreateUser.IsActive" type="hidden" value="true" />

                    <div class="form-grid">
                        <div class="span-2">
                            <label asp-for="CreateUser.FullName" class="form-label"></label>
                            <input asp-for="CreateUser.FullName" class="form-control" />
                            <span asp-validation-for="CreateUser.FullName" class="text-danger"></span>
                        </div>

                        <div class="span-2">
                            <label asp-for="CreateUser.Email" class="form-label"></label>
                            <input asp-for="CreateUser.Email" class="form-control" autocomplete="username" />
                            <span asp-validation-for="CreateUser.Email" class="text-danger"></span>
                        </div>

                        <div>
                            <label asp-for="CreateUser.Password" class="form-label"></label>
                            <div class="password-field">
                                <input asp-for="CreateUser.Password" class="form-control password-input" autocomplete="new-password" />
                                <button type="button" class="password-toggle" data-password-toggle data-password-target="CreateUser_Password" aria-label="Show password" aria-pressed="false">
                                    <span class="password-toggle-icon password-toggle-show" aria-hidden="true">
                                        <svg viewBox="0 0 24 24" fill="none">
                                            <path d="M2 12C3.73 8.39 7.53 6 12 6C16.47 6 20.27 8.39 22 12C20.27 15.61 16.47 18 12 18C7.53 18 3.73 15.61 2 12Z" />
                                            <circle cx="12" cy="12" r="3.2" />
                                        </svg>
                                    </span>
                                    <span class="password-toggle-icon password-toggle-hide" aria-hidden="true">
                                        <svg viewBox="0 0 24 24" fill="none">
                                            <path d="M3 4L21 20" />
                                            <path d="M10.58 10.58C10.22 10.94 10 11.44 10 12C10 13.1 10.9 14 12 14C12.56 14 13.06 13.78 13.42 13.42" />
                                            <path d="M9.88 5.09C10.57 4.98 11.28 4.92 12 4.92C16.47 4.92 20.27 7.31 22 10.92C21.18 12.63 19.95 14.08 18.44 15.16" />
                                            <path d="M6.11 6.58C4.42 7.58 3.03 9.06 2 10.92C3.73 14.53 7.53 16.92 12 16.92C13.21 16.92 14.37 16.74 15.44 16.4" />
                                        </svg>
                                    </span>
                                </button>
                            </div>
                            <span asp-validation-for="CreateUser.Password" class="text-danger"></span>
                        </div>

                        <div>
                            <label asp-for="CreateUser.ConfirmPassword" class="form-label"></label>
                            <div class="password-field">
                                <input asp-for="CreateUser.ConfirmPassword" class="form-control password-input" autocomplete="new-password" />
                                <button type="button" class="password-toggle" data-password-toggle data-password-target="CreateUser_ConfirmPassword" aria-label="Show password" aria-pressed="false">
                                    <span class="password-toggle-icon password-toggle-show" aria-hidden="true">
                                        <svg viewBox="0 0 24 24" fill="none">
                                            <path d="M2 12C3.73 8.39 7.53 6 12 6C16.47 6 20.27 8.39 22 12C20.27 15.61 16.47 18 12 18C7.53 18 3.73 15.61 2 12Z" />
                                            <circle cx="12" cy="12" r="3.2" />
                                        </svg>
                                    </span>
                                    <span class="password-toggle-icon password-toggle-hide" aria-hidden="true">
                                        <svg viewBox="0 0 24 24" fill="none">
                                            <path d="M3 4L21 20" />
                                            <path d="M10.58 10.58C10.22 10.94 10 11.44 10 12C10 13.1 10.9 14 12 14C12.56 14 13.06 13.78 13.42 13.42" />
                                            <path d="M9.88 5.09C10.57 4.98 11.28 4.92 12 4.92C16.47 4.92 20.27 7.31 22 10.92C21.18 12.63 19.95 14.08 18.44 15.16" />
                                            <path d="M6.11 6.58C4.42 7.58 3.03 9.06 2 10.92C3.73 14.53 7.53 16.92 12 16.92C13.21 16.92 14.37 16.74 15.44 16.4" />
                                        </svg>
                                    </span>
                                </button>
                            </div>
                            <span asp-validation-for="CreateUser.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="span-2">
                            <label asp-for="CreateUser.Role" class="form-label"></label>
                            <div class="modal-select-wrap">
                                <select asp-for="CreateUser.Role" class="form-select modal-select">
                                    @foreach (var role in Model.AvailableRoles)
                                    {
                                        <option value="@role">@role</option>
                                    }
                                </select>
                            </div>
                            <span asp-validation-for="CreateUser.Role" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="modal-footer user-modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add User</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editUserModal" tabindex="-1" aria-labelledby="editUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content user-modal">
            <form asp-action="Update" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Page" value="@Model.Query.Page" />
                <input type="hidden" name="PageSize" value="@Model.Query.PageSize" />
                <input type="hidden" name="SearchTerm" value="@Model.Query.SearchTerm" />
                <input asp-for="EditUser.Id" type="hidden" />

                <div class="modal-header user-modal-header">
                    <div>
                        <h3 class="modal-title" id="editUserModalLabel">Edit User</h3>
                        <p class="user-modal-subtitle">Update the selected user's information.</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body user-modal-body">
                    <div asp-validation-summary="ModelOnly" class="message-banner user-validation-summary text-danger"></div>
                    <input asp-for="EditUser.IsActive" type="hidden" value="true" />

                    <div class="form-grid">
                        <div class="span-2">
                            <label asp-for="EditUser.FullName" class="form-label"></label>
                            <input asp-for="EditUser.FullName" class="form-control" />
                            <span asp-validation-for="EditUser.FullName" class="text-danger"></span>
                        </div>

                        <div class="span-2">
                            <label asp-for="EditUser.Email" class="form-label"></label>
                            <input asp-for="EditUser.Email" class="form-control" autocomplete="username" />
                            <span asp-validation-for="EditUser.Email" class="text-danger"></span>
                        </div>

                        <div class="span-2">
                            <label asp-for="EditUser.Role" class="form-label"></label>
                            <div class="modal-select-wrap">
                                <select asp-for="EditUser.Role" class="form-select modal-select">
                                    @foreach (var role in Model.AvailableRoles)
                                    {
                                        <option value="@role">@role</option>
                                    }
                                </select>
                            </div>
                            <span asp-validation-for="EditUser.Role" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="modal-footer user-modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteUserModal" tabindex="-1" aria-labelledby="deleteUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content user-modal">
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Page" value="@Model.Query.Page" />
                <input type="hidden" name="PageSize" value="@Model.Query.PageSize" />
                <input type="hidden" name="SearchTerm" value="@Model.Query.SearchTerm" />
                <input type="hidden" name="id" id="deleteUserId" />

                <div class="modal-header user-modal-header">
                    <div>
                        <h3 class="modal-title" id="deleteUserModalLabel">Delete User</h3>
                        <p class="user-modal-subtitle">This action cannot be undone.</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body user-modal-body">
                    <p class="delete-confirmation-copy">
                        Are you sure you want to delete <strong id="deleteUserName">this user</strong>?
                    </p>
                </div>

                <div class="modal-footer user-modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">No</button>
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const createModalElement = document.getElementById('createUserModal');
            const editModalElement = document.getElementById('editUserModal');
            const deleteModalElement = document.getElementById('deleteUserModal');
            const createForm = createModalElement?.querySelector('form') ?? null;
            const editForm = editModalElement?.querySelector('form') ?? null;
            const deleteUserId = document.getElementById('deleteUserId');
            const deleteUserName = document.getElementById('deleteUserName');
            const getUserUrl = '@Url.Action("GetById", "Users")';
            const activeModal = '@Model.ActiveModal';
            const pageSizeSelect = document.getElementById('users-page-size');
            const searchForm = document.querySelector('.users-search-form');
            const searchInput = document.getElementById('users-table-search');
            const modalElements = [createModalElement, editModalElement, deleteModalElement].filter(Boolean);
            let keepCreateValidationOnFirstShow = activeModal === 'create';
            let keepEditValidationOnFirstShow = activeModal === 'edit';
            let suppressEditResetOnShow = false;
            let searchDebounceId = 0;

            modalElements.forEach(modalElement => {
                if (modalElement.parentElement !== document.body) {
                    document.body.appendChild(modalElement);
                }
            });

            const clearValidationState = form => {
                if (!form) {
                    return;
                }

                if (window.jQuery) {
                    const formValidator = window.jQuery(form).data('validator');
                    formValidator?.resetForm();
                }

                form.querySelectorAll('.input-validation-error, .is-invalid').forEach(element => {
                    element.classList.remove('input-validation-error', 'is-invalid');
                    element.removeAttribute('aria-invalid');
                });

                form.querySelectorAll('.field-validation-error').forEach(element => {
                    element.classList.remove('field-validation-error');
                    element.classList.add('field-validation-valid');
                    element.innerHTML = '';
                });

                form.querySelectorAll('.validation-summary-errors').forEach(element => {
                    element.classList.remove('validation-summary-errors');
                    element.classList.add('validation-summary-valid');
                    const summaryList = element.querySelector('ul') ?? document.createElement('ul');
                    summaryList.innerHTML = '';

                    if (!element.contains(summaryList)) {
                        element.appendChild(summaryList);
                    }
                });
            };

            const resetPasswordState = form => {
                if (!form) {
                    return;
                }

                form.querySelectorAll('.password-input').forEach(input => {
                    input.type = 'password';
                });

                form.querySelectorAll('[data-password-toggle]').forEach(toggle => {
                    toggle.classList.remove('is-visible');
                    toggle.setAttribute('aria-pressed', 'false');
                    toggle.setAttribute('aria-label', 'Show password');
                });
            };

            const resetCreateFormFields = form => {
                if (!form) {
                    return;
                }

                form.querySelectorAll('input:not([type="hidden"]):not([type="checkbox"]):not([type="radio"])').forEach(input => {
                    input.value = '';
                });

                const roleSelect = form.querySelector('select[name="CreateUser.Role"]');

                if (roleSelect) {
                    roleSelect.value = 'Cashier';

                    if (!roleSelect.value && roleSelect.options.length > 0) {
                        roleSelect.selectedIndex = 0;
                    }
                }

                const isActiveInput = form.querySelector('input[name="CreateUser.IsActive"]');

                if (isActiveInput) {
                    isActiveInput.value = 'true';
                }
            };

            const resetModalState = (form, resetFields) => {
                clearValidationState(form);
                resetPasswordState(form);
                resetFields?.(form);
            };

            const registerDismissReset = (modalElement, form, resetFields) => {
                if (!modalElement || !form) {
                    return;
                }

                modalElement.addEventListener('hide.bs.modal', () => {
                    resetModalState(form, resetFields);
                });

                modalElement.querySelectorAll('[data-bs-dismiss="modal"]').forEach(button => {
                    button.addEventListener('click', () => {
                        resetModalState(form, resetFields);
                    });
                });
            };

            registerDismissReset(createModalElement, createForm, resetCreateFormFields);
            registerDismissReset(editModalElement, editForm);

            createModalElement?.addEventListener('hidden.bs.modal', () => {
                resetModalState(createForm, resetCreateFormFields);
            });

            editModalElement?.addEventListener('hidden.bs.modal', () => {
                resetModalState(editForm);
            });

            createModalElement?.addEventListener('show.bs.modal', () => {
                if (keepCreateValidationOnFirstShow) {
                    keepCreateValidationOnFirstShow = false;
                    return;
                }

                resetModalState(createForm, resetCreateFormFields);
            });

            editModalElement?.addEventListener('show.bs.modal', () => {
                if (keepEditValidationOnFirstShow) {
                    keepEditValidationOnFirstShow = false;
                    return;
                }

                if (suppressEditResetOnShow) {
                    suppressEditResetOnShow = false;
                    return;
                }

                resetModalState(editForm);
            });

            document.querySelectorAll('[data-user-edit]').forEach(button => {
                button.addEventListener('click', async () => {
                    const userId = button.getAttribute('data-user-id');

                    if (!userId || !editModalElement) {
                        return;
                    }

                    try {
                        const response = await fetch(`${getUserUrl}?id=${encodeURIComponent(userId)}`, {
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        });

                        if (!response.ok) {
                            throw new Error('Unable to load user details.');
                        }

                        const user = await response.json();
                        resetModalState(editForm);
                        document.getElementById('EditUser_Id').value = user.id ?? '';
                        document.getElementById('EditUser_FullName').value = user.fullName ?? '';
                        document.getElementById('EditUser_Email').value = user.email ?? '';
                        document.getElementById('EditUser_Role').value = user.role ?? 'Cashier';

                        suppressEditResetOnShow = true;
                        bootstrap.Modal.getOrCreateInstance(editModalElement).show();
                    } catch (error) {
                        window.alert('Unable to load the selected user.');
                    }
                });
            });

            document.querySelectorAll('[data-user-delete]').forEach(button => {
                button.addEventListener('click', () => {
                    if (!deleteModalElement || !deleteUserId || !deleteUserName) {
                        return;
                    }

                    deleteUserId.value = button.getAttribute('data-user-id') ?? '';
                    deleteUserName.textContent = button.getAttribute('data-user-name') ?? 'this user';
                    bootstrap.Modal.getOrCreateInstance(deleteModalElement).show();
                });
            });

            if (activeModal === 'create' && createModalElement) {
                bootstrap.Modal.getOrCreateInstance(createModalElement).show();
            }

            if (activeModal === 'edit' && editModalElement) {
                bootstrap.Modal.getOrCreateInstance(editModalElement).show();
            }

            pageSizeSelect?.addEventListener('change', () => {
                pageSizeSelect.form?.submit();
            });

            searchInput?.addEventListener('input', () => {
                window.clearTimeout(searchDebounceId);
                searchDebounceId = window.setTimeout(() => {
                    searchForm?.requestSubmit();
                }, 350);
            });

            searchInput?.addEventListener('keydown', event => {
                if (event.key !== 'Enter') {
                    return;
                }

                event.preventDefault();
                window.clearTimeout(searchDebounceId);
                searchForm?.requestSubmit();
            });

            searchInput?.addEventListener('search', () => {
                window.clearTimeout(searchDebounceId);
                searchForm?.requestSubmit();
            });

            document.querySelectorAll('[data-password-toggle]').forEach(toggle => {
                toggle.addEventListener('click', () => {
                    const targetId = toggle.getAttribute('data-password-target');
                    const targetInput = targetId ? document.getElementById(targetId) : null;

                    if (!targetInput) {
                        return;
                    }

                    const isVisible = targetInput.type === 'text';
                    targetInput.type = isVisible ? 'password' : 'text';
                    toggle.classList.toggle('is-visible', !isVisible);
                    toggle.setAttribute('aria-pressed', (!isVisible).toString());
                    toggle.setAttribute('aria-label', isVisible ? 'Show password' : 'Hide password');
                });
            });
        })();
    </script>
}
