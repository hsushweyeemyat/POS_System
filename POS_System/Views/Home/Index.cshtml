@{
    ViewData["Title"] = "Cashier";

    var orderCards = new[]
    {
        new { Guest = "Jesica", Ticket = "#016", Count = 7, Table = "Table 3C", Summary = "1x Dimsum 3x Coffee Latte", Status = "Cook", StatusClass = "is-warning" },
        new { Guest = "Albert", Ticket = "#015", Count = 3, Table = "Table 1C", Summary = "2x Lime 3x Grilled Tilapia", Status = "Cook", StatusClass = "is-warning" },
        new { Guest = "John Cen", Ticket = "#014", Count = 4, Table = "Table 6C", Summary = "3x Dimsum 3x Lemon Tea", Status = "Finished", StatusClass = "is-success" },
        new { Guest = "Mikey", Ticket = "#013", Count = 5, Table = "Table 2C", Summary = "5x Egg Fried Rice 2x Lime", Status = "Finished", StatusClass = "is-success" },
        new { Guest = "Alex", Ticket = "#012", Count = 5, Table = "Table 5A", Summary = "3x Coffee Latte 2x Caramel Boba", Status = "Pickup", StatusClass = "active" }
    };

    var categories = new[]
    {
        new { Name = "All Menu", Count = "40 Items", IsActive = true },
        new { Name = "Fried Rice", Count = "4 Items", IsActive = false },
        new { Name = "Beverages", Count = "10 Items", IsActive = false },
        new { Name = "Dimsum", Count = "14 Items", IsActive = false },
        new { Name = "Burger", Count = "6 Items", IsActive = false },
        new { Name = "French Fries", Count = "6 Items", IsActive = false }
    };

    var products = new[]
    {
        new { Name = "Grilled Tilapia", Tag = "Food", TagClass = "tag-food", Price = "MMK 3.00", Note = "Charred citrus glaze with herb rice.", Tone = "tilapia", Code = "GT" },
        new { Name = "Caramel Boba", Tag = "Beverage", TagClass = "tag-beverage", Price = "MMK 1.50", Note = "Brown sugar milk tea with pearl finish.", Tone = "boba", Code = "CB" },
        new { Name = "Egg Fried Rice", Tag = "Food", TagClass = "tag-food", Price = "MMK 2.50", Note = "Wok fried rice with scallion and chili crunch.", Tone = "rice", Code = "ER" },
        new { Name = "Lemon Tea", Tag = "Beverage", TagClass = "tag-beverage", Price = "MMK 1.00", Note = "House black tea with fresh lemon syrup.", Tone = "lemon", Code = "LT" },
        new { Name = "Dimsum", Tag = "Food", TagClass = "tag-food", Price = "MMK 3.50", Note = "Steamed dumplings with sesame soy dip.", Tone = "dimsum", Code = "DM" },
        new { Name = "Coffee Latte", Tag = "Beverage", TagClass = "tag-beverage", Price = "MMK 1.50", Note = "Velvety espresso milk pour for rush orders.", Tone = "latte", Code = "CL" }
    };

    var currentOrder = new[]
    {
        new { Name = "Lemon tea", Price = "MMK 1.00", Quantity = 1, Tone = "lemon", Code = "LT" },
        new { Name = "Dimsum", Price = "MMK 3.50", Quantity = 2, Tone = "dimsum", Code = "DM" },
        new { Name = "Caramel Boba", Price = "MMK 1.50", Quantity = 1, Tone = "boba", Code = "CB" },
        new { Name = "Coffee Latte", Price = "MMK 1.50", Quantity = 1, Tone = "latte", Code = "CL" }
    };
}

<div class="page-shell pos-view">
    <div class="pos-grid">
        <div class="pos-column">
            <section class="section-card order-strip-panel">
                <div class="section-heading">
                    <div class="section-heading-copy">
                        <h2 class="section-title">Order List</h2>
                        <p class="section-description">10 open tickets moving across the dining floor.</p>
                    </div>
                    <span class="section-meta-pill">Counter live</span>
                </div>

                <div class="order-strip">
                    @foreach (var order in orderCards)
                    {
                        <article class="order-card">
                            <div class="order-card-top">
                                <div class="order-card-identity">
                                    <span class="status-dot" aria-hidden="true"></span>
                                    <div>
                                        <h3>@order.Guest</h3>
                                        <p>@order.Count items · @order.Table</p>
                                    </div>
                                </div>
                                <span class="ticket-id">@order.Ticket</span>
                            </div>

                            <p class="order-card-summary">Order: @order.Summary</p>
                            <span class="status-chip @order.StatusClass">@order.Status</span>
                        </article>
                    }
                </div>
            </section>

            <section class="section-card">
                <div class="section-heading">
                    <div class="section-heading-copy">
                        <h2 class="section-title">Menu</h2>
                        <p class="section-description">Fast entry favorites for the cashier lane.</p>
                    </div>

                    <label class="board-search menu-search" for="menu-search">
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <circle cx="11" cy="11" r="6"></circle>
                            <path d="M20 20L16.65 16.65"></path>
                        </svg>
                        <input id="menu-search" type="search" placeholder="Search menu" />
                    </label>
                </div>

                <div class="category-strip">
                    @foreach (var category in categories)
                    {
                        <button type="button" class="category-chip @(category.IsActive ? "active" : string.Empty)">
                            <div class="category-copy">
                                <strong>@category.Name</strong>
                                <span>@category.Count</span>
                            </div>
                        </button>
                    }
                </div>

                <div class="menu-grid">
                    @foreach (var product in products)
                    {
                        <article class="product-card">
                            <div class="product-media media-@product.Tone">
                                <span>@product.Code</span>
                            </div>

                            <div class="product-copy">
                                <h3 class="product-name">@product.Name</h3>
                                <p class="product-description">@product.Note</p>
                            </div>

                            <div class="product-foot">
                                <div>
                                    <span class="product-tag @product.TagClass">@product.Tag</span>
                                    <strong class="price-tag">@product.Price</strong>
                                </div>

                                <button type="button" class="circle-button primary" aria-label="Add @product.Name">
                                    +
                                </button>
                            </div>
                        </article>
                    }
                </div>
            </section>
        </div>

        <aside class="section-card invoice-panel">
            <div class="section-heading">
                <div class="section-heading-copy">
                    <h2 class="section-title">Current Order</h2>
                    <p class="section-description">Seat 3C · table service</p>
                </div>

                <button type="button" class="circle-button" aria-label="Clear current order">
                    x
                </button>
            </div>

            <div class="segmented-control" aria-label="Service type">
                <button type="button" class="segmented-chip active">Take Away</button>
                <button type="button" class="segmented-chip">Dine In</button>
            </div>

            <div class="invoice-list">
                @foreach (var item in currentOrder)
                {
                    <article class="invoice-item">
                        <div class="invoice-thumb media-@item.Tone">
                            <span>@item.Code</span>
                        </div>

                        <div class="invoice-item-main">
                            <div class="invoice-item-head">
                                <strong>@item.Name</strong>
                                <span class="invoice-item-price">@item.Price</span>
                            </div>

                            <div class="quantity-pill">
                                <button type="button" class="circle-button" aria-label="Decrease @item.Name quantity">-</button>
                                <span>@item.Quantity</span>
                                <button type="button" class="circle-button primary" aria-label="Increase @item.Name quantity">+</button>
                            </div>
                        </div>
                    </article>
                }
            </div>

            <div class="invoice-summary">
                <div class="invoice-summary-row">
                    <span>Sub Total</span>
                    <strong>MMK 7.50</strong>
                </div>
                <div class="invoice-summary-row">
                    <span>Tax (11%)</span>
                    <strong>MMK 3.00</strong>
                </div>
                <div class="invoice-summary-row total">
                    <span>Total</span>
                    <strong>MMK 10.50</strong>
                </div>
            </div>

            <div class="message-banner">
                <strong>Ready to finalize</strong>
                <p>This counter view completes the order directly from the cart in one step.</p>
            </div>

            <button type="button" class="btn btn-primary w-100">Complete Order</button>
        </aside>
    </div>
</div>
