@{
    ViewData["Title"] = "Kitchen Board";
}

<div class="page-shell">
    <section class="board-tabs" aria-label="Kitchen queue filters">
        <button type="button" class="board-tab">
            <span class="board-count">5</span>
            <span>New</span>
        </button>
        <button type="button" class="board-tab active">
            <span class="board-count">5</span>
            <span>Assigned</span>
        </button>
        <button type="button" class="board-tab">
            <span class="board-count">12</span>
            <span>Cooking</span>
        </button>
        <button type="button" class="board-tab">
            <span class="board-count">10</span>
            <span>Out for delivery</span>
        </button>
        <button type="button" class="board-tab">
            <span class="board-count">85</span>
            <span>Complete</span>
        </button>
    </section>

    <section class="board-toolbar">
        <div class="board-heading">
            <h2>Assigned queue</h2>
            <p>Station routing and prep ownership are grouped here for kitchen staff.</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Back to orders</a>
    </section>

    <section class="ticket-grid">
        <article class="ticket-card">
            <div class="ticket-head">
                <div class="ticket-person">
                    <span class="ticket-timer">0:09</span>
                    <div>
                        <h3 class="ticket-customer">Margo Fields</h3>
                        <p class="ticket-address">211 Berkeley Ave, Suite 3</p>
                    </div>
                </div>
                <span class="ticket-id">#94012</span>
            </div>

            <div class="ticket-total-row">
                <span>Total</span>
                <strong>$22.45</strong>
            </div>

            <div class="station-grid">
                <article class="station-tile station-green">
                    <span>Prep lane</span>
                    <strong>North Kitchen</strong>
                    <small>Priority for wraps and bowls</small>
                </article>
                <article class="station-tile station-blue">
                    <span>Runner</span>
                    <strong>Prep Station B</strong>
                    <small>Courier staging shelf</small>
                </article>
                <button type="button" class="ticket-menu" aria-label="More options">...</button>
            </div>
        </article>

        <article class="ticket-card">
            <div class="ticket-head">
                <div class="ticket-person">
                    <span class="ticket-timer">0:14</span>
                    <div>
                        <h3 class="ticket-customer">Elena Torres</h3>
                        <p class="ticket-address">84 Pine Crest Ln</p>
                    </div>
                </div>
                <span class="ticket-id">#94018</span>
            </div>

            <div class="ticket-total-row">
                <span>Total</span>
                <strong>$18.90</strong>
            </div>

            <div class="station-grid">
                <article class="station-tile station-amber">
                    <span>Cook line</span>
                    <strong>Grill Line</strong>
                    <small>Protein and finishing queue</small>
                </article>
                <article class="station-tile station-green">
                    <span>Runner</span>
                    <strong>West Station</strong>
                    <small>Packing and receipt tagging</small>
                </article>
                <button type="button" class="ticket-menu" aria-label="More options">...</button>
            </div>
        </article>
    </section>

    <section class="board-toolbar">
        <div class="board-heading">
            <h2>Cooking and dispatch</h2>
            <p>Use the active tickets below to coordinate prep, packing, and handoff.</p>
        </div>

        <label class="board-search" for="kitchen-search">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="11" cy="11" r="6"></circle>
                <path d="M20 20L16.65 16.65"></path>
            </svg>
            <input id="kitchen-search" type="search" placeholder="Search tickets" />
        </label>
    </section>

    <section class="ticket-grid">
        <article class="ticket-card">
            <div class="ticket-head">
                <div class="ticket-person">
                    <span class="ticket-timer">08:42</span>
                    <div>
                        <h3 class="ticket-customer">Patrick Hughes</h3>
                        <p class="ticket-address">59 Rosemont Ave</p>
                    </div>
                </div>
                <div>
                    <div class="ticket-id">#94002</div>
                    <div class="ticket-status is-cooking">Cooking</div>
                </div>
            </div>

            <ul class="ticket-items">
                <li class="ticket-item">
                    <div class="ticket-item-main">
                        <span class="item-dot dot-amber"></span>
                        <span>BBQ chicken wrap</span>
                    </div>
                    <strong>$5.20</strong>
                </li>
                <li class="ticket-item">
                    <div class="ticket-item-main">
                        <span class="item-dot dot-green"></span>
                        <span>Seasonal greens</span>
                    </div>
                    <strong>$3.85</strong>
                </li>
                <li class="ticket-item item-muted">
                    <div class="ticket-item-main">
                        <span class="item-dot dot-blue"></span>
                        <span>Extra dressing</span>
                    </div>
                    <strong>$1.65</strong>
                </li>
            </ul>

            <div class="ticket-total-row">
                <span>Total</span>
                <strong>$10.70</strong>
            </div>
        </article>

        <article class="ticket-card">
            <div class="ticket-head">
                <div class="ticket-person">
                    <span class="ticket-timer">11:06</span>
                    <div>
                        <h3 class="ticket-customer">Chloe Sanders</h3>
                        <p class="ticket-address">13 Willow Park</p>
                    </div>
                </div>
                <div>
                    <div class="ticket-id">#94008</div>
                    <div class="ticket-status is-delivery">Out for delivery</div>
                </div>
            </div>

            <ul class="ticket-items">
                <li class="ticket-item">
                    <div class="ticket-item-main">
                        <span class="item-dot dot-blue"></span>
                        <span>Signature noodle bowl</span>
                    </div>
                    <strong>$6.40</strong>
                </li>
                <li class="ticket-item">
                    <div class="ticket-item-main">
                        <span class="item-dot dot-green"></span>
                        <span>Citrus soda</span>
                    </div>
                    <strong>$2.10</strong>
                </li>
                <li class="ticket-item item-muted">
                    <div class="ticket-item-main">
                        <span class="item-dot dot-rose"></span>
                        <span>Delivery note added</span>
                    </div>
                    <strong>$2.95</strong>
                </li>
            </ul>

            <div class="ticket-total-row">
                <span>Total</span>
                <strong>$11.45</strong>
            </div>
        </article>
    </section>
</div>
