@{
    ViewData["Title"] = "Security Notes";
}

<div class="page-shell">
    <section class="board-tabs" aria-label="Security sections">
        <button type="button" class="board-tab active">
            <span class="board-count">3</span>
            <span>Authentication</span>
        </button>
        <button type="button" class="board-tab">
            <span class="board-count">2</span>
            <span>Authorization</span>
        </button>
        <button type="button" class="board-tab">
            <span class="board-count">1</span>
            <span>Monitoring</span>
        </button>
    </section>

    <section class="board-toolbar">
        <div class="board-heading">
            <h2>Security board</h2>
            <p>Protection notes now live inside the same service-console system as the operational screens.</p>
        </div>
    </section>

    <section class="security-grid">
        <article class="security-tile">
            <strong>Cookie-based sign-in</strong>
            <p>The app uses the application cookie scheme rather than ASP.NET Identity tables.</p>
        </article>

        <article class="security-tile">
            <strong>Role claims from <code>Tbl_Users</code></strong>
            <p>Admin and Cashier experiences are routed using the custom user store and claims factory.</p>
        </article>

        <article class="security-tile">
            <strong>Active user validation</strong>
            <p>Inactive users are rejected at login and during cookie refresh to prevent stale access.</p>
        </article>
    </section>

    <section class="section-card inset-card">
        <div class="section-heading">
            <div>
                <p class="section-meta mb-2">Implementation Notes</p>
                <h2 class="section-title">Current protection layers</h2>
            </div>
        </div>

        <div class="info-list">
            <div class="info-row">
                <div>
                    <strong>Fallback authorization</strong>
                    <span>Authenticated access is required by default across the application.</span>
                </div>
            </div>

            <div class="info-row">
                <div>
                    <strong>Role-based gates</strong>
                    <span>Admin-only and shared sales policies decide which surfaces users can open.</span>
                </div>
            </div>

            <div class="info-row">
                <div>
                    <strong>Database recheck</strong>
                    <span>Each cookie refresh verifies the account still exists, remains active, and keeps the same role.</span>
                </div>
            </div>
        </div>
    </section>
</div>
