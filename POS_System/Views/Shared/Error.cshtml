@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="status-page">
    <div class="section-card">
        <div class="error-code">System Error</div>
        <div class="board-heading">
            <h2>Something interrupted this request.</h2>
            <p>The board could not finish loading this action.</p>
        </div>
        <p class="status-copy">
            The refreshed POS shell is still wrapped by the standard ASP.NET Core error pipeline, so detailed diagnostics remain hidden unless the app is running in Development.
        </p>

        @if (Model.ShowRequestId)
        {
            <div class="message-banner">
                <strong>Request ID</strong>
                <p><code>@Model.RequestId</code></p>
            </div>
        }

        <div class="divider"></div>

        <div class="info-list">
            <div class="info-row">
                <div>
                    <strong>Development mode</strong>
                    <span>Enable <code>ASPNETCORE_ENVIRONMENT=Development</code> for richer exception details during local debugging.</span>
                </div>
            </div>

            <div class="info-row">
                <div>
                    <strong>Production safety</strong>
                    <span>Detailed exception pages should stay disabled in deployed environments to avoid leaking sensitive information.</span>
                </div>
            </div>
        </div>
    </div>
</section>
