@using System.Linq
@{
    var fullName = User.FindFirst("full_name")?.Value ?? User.Identity?.Name ?? "Guest User";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Guest";
    var isSignedIn = User.Identity?.IsAuthenticated ?? false;
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var isAuthPage = string.Equals(controller, "Account", StringComparison.OrdinalIgnoreCase)
        && (string.Equals(action, "Login", StringComparison.OrdinalIgnoreCase)
            || string.Equals(action, "AccessDenied", StringComparison.OrdinalIgnoreCase));
    var bodyClass = ViewData["BodyClass"]?.ToString() ?? string.Empty;
    var isSalesCounter = string.Equals(controller, "Sales", StringComparison.OrdinalIgnoreCase)
        && !string.Equals(action, "History", StringComparison.OrdinalIgnoreCase);
    var isSalesHistory = string.Equals(controller, "Sales", StringComparison.OrdinalIgnoreCase)
        && string.Equals(action, "History", StringComparison.OrdinalIgnoreCase);
    var initials = string.Concat(fullName
        .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Take(2)
        .Select(part => char.ToUpperInvariant(part[0])));

    if (string.IsNullOrWhiteSpace(initials))
    {
        initials = "PS";
    }

    var shiftLabel = isSignedIn ? $"{role} station" : "Awaiting sign in";
    var shiftDate = DateTime.Now.ToString("d MMM yyyy");
    var shiftTime = DateTime.Now.ToString("hh:mm:ss tt");
    var pageTitle = ViewData["Title"]?.ToString()
        ?? (string.IsNullOrWhiteSpace(controller) ? "Workspace" : controller);
    var workspaceContext = controller switch
    {
        "Sales" when string.Equals(action, "History", StringComparison.OrdinalIgnoreCase) => "Transaction ledger",
        "Sales" when string.Equals(action, "Invoice", StringComparison.OrdinalIgnoreCase) => "Checkout complete",
        "Sales" => "Checkout workspace",
        "Products" => "Catalog control",
        "Categories" => "Catalog control",
        "Users" => "Access control",
        "Home" when string.Equals(action, "Index", StringComparison.OrdinalIgnoreCase) => "Counter view",
        "Home" when string.Equals(action, "Sales", StringComparison.OrdinalIgnoreCase) => "Kitchen board",
        _ => "Operations workspace"
    };
    var bodyClasses = string.Join(" ", new[]
    {
        bodyClass,
        isAuthPage ? "auth-page" : "app-page"
    }.Where(value => !string.IsNullOrWhiteSpace(value)));
    var searchPrompt = controller switch
    {
        "Sales" when string.Equals(action, "History", StringComparison.OrdinalIgnoreCase) => "Search invoices and review completed sale records",
        "Users" => "Search staff, roles, and access",
        "Products" => "Browse products, prices, and stock",
        "Categories" => "Filter catalog sections and records",
        "Sales" => "Search products, manage the cart, and complete checkout",
        "Home" when string.Equals(action, "Sales", StringComparison.OrdinalIgnoreCase) => "Track kitchen tickets and dispatch lanes",
        "Home" when string.Equals(action, "Admin", StringComparison.OrdinalIgnoreCase) => "Open settings, staffing, and catalog controls",
        "Home" when string.Equals(action, "Privacy", StringComparison.OrdinalIgnoreCase) => "Review security notes and access rules",
        _ => "Scan orders, menu items, and service flow"
    };

    string NavState(string targetController, string? targetAction = null)
    {
        var controllerMatch = string.Equals(controller, targetController, StringComparison.OrdinalIgnoreCase);
        var actionMatch = targetAction is null || string.Equals(action, targetAction, StringComparison.OrdinalIgnoreCase);
        return controllerMatch && actionMatch ? "active" : string.Empty;
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - POS System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/theme-refresh.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/design-reference-live.css" asp-append-version="true" />
    @if (string.Equals(controller, "Sales", StringComparison.OrdinalIgnoreCase)
        && string.Equals(action, "Index", StringComparison.OrdinalIgnoreCase))
    {
        <link rel="stylesheet" href="~/css/sales-dashboard.css" asp-append-version="true" />
    }
    <link rel="stylesheet" href="~/POS_System.styles.css" asp-append-version="true" />
</head>
<body class="@bodyClasses">
    @if (isAuthPage)
    {
        <main class="auth-shell" role="main">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="pos-shell">
            <aside class="app-sidebar" aria-label="Primary">
                <div class="sidebar-header">
                    <a class="sidebar-brand" asp-controller="Sales" asp-action="Index" aria-label="RetailPOS home">
                        <span class="sidebar-brand-mark" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M5 4.5H19" />
                                <path d="M5 8.5H19" />
                                <path d="M8 12.5H12" />
                                <path d="M4.5 3.5V20.5H19.5V3.5" />
                                <path d="M16 13.5C17.38 13.5 18.5 14.62 18.5 16C18.5 17.38 17.38 18.5 16 18.5C14.62 18.5 13.5 17.38 13.5 16C13.5 14.62 14.62 13.5 16 13.5Z" />
                            </svg>
                        </span>
                        <span class="sidebar-brand-copy">
                            <strong>RetailPOS</strong>
                        </span>
                    </a>
                    <div class="sidebar-divider"></div>
                    <p class="sidebar-menu-title">Workspace</p>
                </div>

                <div class="sidebar-nav-scroll">
                    <nav class="sidebar-nav">
                        <a class="sidebar-link @(isSalesCounter ? "active" : string.Empty)" asp-controller="Sales" asp-action="Index" title="Sales" aria-label="Sales">
                            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M5 4.5H19" />
                                <path d="M5 8.5H19" />
                                <path d="M8 12.5H12" />
                                <path d="M4.5 3.5V20.5H19.5V3.5" />
                                <path d="M16 13.5C17.38 13.5 18.5 14.62 18.5 16C18.5 17.38 17.38 18.5 16 18.5C14.62 18.5 13.5 17.38 13.5 16C13.5 14.62 14.62 13.5 16 13.5Z" />
                            </svg>
                            <span class="sidebar-label">Dashboard</span>
                        </a>
                        <a class="sidebar-link @(isSalesHistory ? "active" : string.Empty)" asp-controller="Sales" asp-action="History" title="Sale History" aria-label="Sale History">
                            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                <path d="M6 4.5H18" />
                                <path d="M6 9H18" />
                                <path d="M6 13.5H13" />
                                <path d="M6 18H13" />
                                <path d="M17.5 14.5L20 17L17.5 19.5" />
                                <path d="M20 17H15" />
                            </svg>
                            <span class="sidebar-label">Sale History</span>
                        </a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a class="sidebar-link @NavState("Users", "Index")" asp-controller="Users" asp-action="Index" title="Users" aria-label="Users">
                                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path d="M8 11C9.66 11 11 9.66 11 8C11 6.34 9.66 5 8 5C6.34 5 5 6.34 5 8C5 9.66 6.34 11 8 11Z" />
                                    <path d="M16.5 10.5C17.88 10.5 19 9.38 19 8C19 6.62 17.88 5.5 16.5 5.5C15.12 5.5 14 6.62 14 8C14 9.38 15.12 10.5 16.5 10.5Z" />
                                    <path d="M3.5 18.5C3.5 15.74 5.74 13.5 8.5 13.5H9C11.76 13.5 14 15.74 14 18.5" />
                                    <path d="M14.5 18.5C14.5 16.43 16.18 14.75 18.25 14.75H18.5C20.57 14.75 22.25 16.43 22.25 18.5" />
                                </svg>
                                <span class="sidebar-label">Users</span>
                            </a>

                            <a class="sidebar-link @NavState("Categories", "Index")" asp-controller="Categories" asp-action="Index" title="Categories" aria-label="Categories">
                                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path d="M12 3L4 7L12 11L20 7L12 3Z" />
                                    <path d="M4 12L12 16L20 12" />
                                    <path d="M4 17L12 21L20 17" />
                                </svg>
                                <span class="sidebar-label">Categories</span>
                            </a>

                            <a class="sidebar-link @NavState("Products", "Index")" asp-controller="Products" asp-action="Index" title="Products" aria-label="Products">
                                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path d="M5 8.5L12 4L19 8.5L12 13L5 8.5Z" />
                                    <path d="M5 8.5V15.5L12 20L19 15.5V8.5" />
                                    <path d="M12 13V20" />
                                </svg>
                                <span class="sidebar-label">Products</span>
                            </a>
                        }
                    </nav>
                </div>

                @if (isSignedIn)
                {
                    <div class="sidebar-footer">
                        <div class="sidebar-footer-card">
                            <div class="sidebar-user-card">
                                <div class="avatar">@initials</div>
                                <div class="sidebar-user-copy">
                                    <strong>@fullName</strong>
                                    <span>@shiftLabel</span>
                                </div>
                            </div>

                            <form asp-controller="Account" asp-action="Logout" method="post" class="sidebar-logout">
                                <button type="submit" class="sidebar-logout-button" aria-label="Logout">
                                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                        <path d="M14 7L19 12L14 17" />
                                        <path d="M19 12H10" />
                                        <path d="M10 4H6.5C5.67 4 5 4.67 5 5.5V18.5C5 19.33 5.67 20 6.5 20H10" />
                                    </svg>
                                    <span>Logout</span>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </aside>

            <div class="app-workspace">
                <main class="workspace-main" role="main">
                    @RenderBody()
                </main>
            </div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
