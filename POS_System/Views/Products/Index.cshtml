@model ProductsIndexViewModel
@{
    ViewData["Title"] = "Products";
    var statusMessage = TempData["StatusMessage"]?.ToString();
    var statusType = TempData["StatusType"]?.ToString() ?? "success";
    var hasProducts = Model.ProductsPage.Items.Count > 0;
    var hasCategories = Model.AvailableCategories.Count > 0;
    var currentPageLabel = Model.ProductsPage.TotalCount == 0 ? "0" : Model.ProductsPage.Page.ToString();
    var pageSummary = Model.ProductsPage.TotalCount == 0
        ? "Page 0 of 0"
        : $"Page {Model.ProductsPage.Page} of {Model.ProductsPage.TotalPages}";
}

<div class="page-shell">
    <section class="users-toolbar">
        <div class="board-heading">
            <h2>Products</h2>
            <p>Manage products, categories, prices, and stock from one searchable inventory table.</p>
        </div>

        <button type="button"
                class="btn btn-primary users-add-button"
                data-bs-toggle="modal"
                data-bs-target="#createProductModal"
                @(hasCategories ? null : "disabled")>
            <span>+</span>
            <span>Add Product</span>
        </button>
    </section>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="message-banner status-banner @(string.Equals(statusType, "error", StringComparison.OrdinalIgnoreCase) ? "is-error" : "is-success")" role="alert">
            @statusMessage
        </div>
    }

    @if (!hasCategories)
    {
        <div class="message-banner status-banner is-error" role="alert">
            Create at least one active category before adding products.
        </div>
    }

    <section class="users-table-controls">
        <form asp-action="Index" method="get" class="users-search-form">
            <label class="users-search" for="products-table-search">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <circle cx="11" cy="11" r="6"></circle>
                    <path d="M20 20L16.65 16.65"></path>
                </svg>
                <input id="products-table-search" name="SearchTerm" type="search" value="@Model.Query.SearchTerm" placeholder="Search products or categories..." autocomplete="off" />
            </label>
            <input type="hidden" name="Page" value="1" />
            <input type="hidden" name="PageSize" value="@Model.Query.PageSize" />
        </form>

        <div class="users-result-pill">
            <span>@Model.ProductsPage.TotalCount</span> results
        </div>
    </section>

    <section class="users-table-card">
        <div class="table-responsive @(hasProducts ? string.Empty : "d-none")">
            <table class="table users-table align-middle mb-0" id="products-data-table">
                <thead>
                    <tr>
                        <th>No.</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th class="users-action-column">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var productEntry in Model.ProductsPage.Items.Select((product, index) => new { product, index }))
                    {
                        var product = productEntry.product;
                        var rowNumber = Model.ProductsPage.FirstItemNumber + productEntry.index;

                        <tr>
                            <td>@rowNumber</td>
                            <td>@product.Name</td>
                            <td>@product.CategoryName</td>
                            <td>MMK @product.Price.ToString("N0")</td>
                            <td>@product.StockQty.ToString("N0")</td>
                            <td>
                                <div class="users-action-group">
                                    <button type="button" class="table-action" data-product-edit data-product-id="@product.Id" aria-label="Edit @product.Name">
                                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                            <path d="M4 20H8L18 10C18.53 9.47 18.53 8.53 18 8L16 6C15.47 5.47 14.53 5.47 14 6L4 16V20Z"></path>
                                            <path d="M13 7L17 11"></path>
                                        </svg>
                                    </button>
                                    <button type="button" class="table-action table-action-danger" data-product-delete data-product-id="@product.Id" data-product-name="@product.Name" aria-label="Delete @product.Name">
                                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                            <path d="M5 7H19"></path>
                                            <path d="M9 7V5.5C9 4.67 9.67 4 10.5 4H13.5C14.33 4 15 4.67 15 5.5V7"></path>
                                            <path d="M8 10V17"></path>
                                            <path d="M12 10V17"></path>
                                            <path d="M16 10V17"></path>
                                            <path d="M6 7L7 19C7.07 19.78 7.72 20.38 8.5 20.38H15.5C16.28 20.38 16.93 19.78 17 19L18 7"></path>
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div id="products-empty-state" class="empty-state users-empty-state @(hasProducts ? "d-none" : string.Empty)">
            <strong>No products found</strong>
            <p>Try another search keyword or add a new product.</p>
        </div>
    </section>

    <section class="datatable-footer">
        <div class="datatable-summary-group">
            <span id="products-page-summary">@pageSummary</span>

            <form asp-action="Index" method="get" class="page-size-form">
                <input type="hidden" name="Page" value="1" />
                <input type="hidden" name="SearchTerm" value="@Model.Query.SearchTerm" />
                <label class="page-size-label" for="products-page-size">Rows</label>
                <div class="page-size-select-wrap">
                    <select id="products-page-size" name="PageSize" class="form-select page-size-select">
                        @foreach (var size in new[] { 5, 10, 25, 50 })
                        {
                            if (Model.Query.PageSize == size)
                            {
                                <option value="@size" selected>@size</option>
                            }
                            else
                            {
                                <option value="@size">@size</option>
                            }
                        }
                    </select>
                </div>
            </form>
        </div>

        <div class="pagination-controls">
            @if (Model.ProductsPage.HasPreviousPage)
            {
                <a class="page-button"
                   asp-action="Index"
                   asp-route-page="@(Model.ProductsPage.Page - 1)"
                   asp-route-pageSize="@Model.Query.PageSize"
                   asp-route-searchTerm="@Model.Query.SearchTerm"
                   aria-label="Previous page">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M14 6L8 12L14 18"></path>
                    </svg>
                </a>
            }
            else
            {
                <span class="page-button disabled" aria-disabled="true">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M14 6L8 12L14 18"></path>
                    </svg>
                </span>
            }

            <span class="page-button active">@currentPageLabel</span>

            @if (Model.ProductsPage.HasNextPage)
            {
                <a class="page-button"
                   asp-action="Index"
                   asp-route-page="@(Model.ProductsPage.Page + 1)"
                   asp-route-pageSize="@Model.Query.PageSize"
                   asp-route-searchTerm="@Model.Query.SearchTerm"
                   aria-label="Next page">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M10 6L16 12L10 18"></path>
                    </svg>
                </a>
            }
            else
            {
                <span class="page-button disabled" aria-disabled="true">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M10 6L16 12L10 18"></path>
                    </svg>
                </span>
            }
        </div>
    </section>
</div>

<div class="modal fade" id="createProductModal" tabindex="-1" aria-labelledby="createProductModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content user-modal">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Page" value="@Model.Query.Page" />
                <input type="hidden" name="PageSize" value="@Model.Query.PageSize" />
                <input type="hidden" name="SearchTerm" value="@Model.Query.SearchTerm" />

                <div class="modal-header user-modal-header">
                    <div>
                        <h3 class="modal-title" id="createProductModalLabel">Add Product</h3>
                        <p class="user-modal-subtitle">Create a new product with category, price, and stock details.</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body user-modal-body">
                    <div asp-validation-summary="ModelOnly" class="message-banner user-validation-summary text-danger"></div>
                    <input asp-for="CreateProduct.IsActive" type="hidden" value="true" />

                    <div class="form-grid">
                        <div class="span-2">
                            <label asp-for="CreateProduct.Name" class="form-label"></label>
                            <input asp-for="CreateProduct.Name" class="form-control" />
                            <span asp-validation-for="CreateProduct.Name" class="text-danger"></span>
                        </div>

                        <div>
                            <label asp-for="CreateProduct.Price" class="form-label"></label>
                            <input asp-for="CreateProduct.Price" class="form-control" min="0" data-product-number-input />
                            <span asp-validation-for="CreateProduct.Price" class="text-danger"></span>
                        </div>

                        <div>
                            <label asp-for="CreateProduct.StockQty" class="form-label"></label>
                            <input asp-for="CreateProduct.StockQty" class="form-control" min="0" data-product-number-input />
                            <span asp-validation-for="CreateProduct.StockQty" class="text-danger"></span>
                        </div>

                        <div class="span-2">
                            <label asp-for="CreateProduct.CategoryId" class="form-label"></label>
                            <div class="modal-select-wrap">
                                <select asp-for="CreateProduct.CategoryId" class="form-select modal-select">
                                    <option value="">Select category</option>
                                    @foreach (var category in Model.AvailableCategories)
                                    {
                                        <option value="@category.Id">@category.Name</option>
                                    }
                                </select>
                            </div>
                            <span asp-validation-for="CreateProduct.CategoryId" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="modal-footer user-modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" @(hasCategories ? null : "disabled")>Add Product</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editProductModal" tabindex="-1" aria-labelledby="editProductModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content user-modal">
            <form asp-action="Update" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Page" value="@Model.Query.Page" />
                <input type="hidden" name="PageSize" value="@Model.Query.PageSize" />
                <input type="hidden" name="SearchTerm" value="@Model.Query.SearchTerm" />
                <input asp-for="EditProduct.Id" type="hidden" />

                <div class="modal-header user-modal-header">
                    <div>
                        <h3 class="modal-title" id="editProductModalLabel">Edit Product</h3>
                        <p class="user-modal-subtitle">Update the selected product's catalog details.</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body user-modal-body">
                    <div asp-validation-summary="ModelOnly" class="message-banner user-validation-summary text-danger"></div>
                    <input asp-for="EditProduct.IsActive" type="hidden" value="true" />

                    <div class="form-grid">
                        <div class="span-2">
                            <label asp-for="EditProduct.Name" class="form-label"></label>
                            <input asp-for="EditProduct.Name" class="form-control" />
                            <span asp-validation-for="EditProduct.Name" class="text-danger"></span>
                        </div>

                        <div>
                            <label asp-for="EditProduct.Price" class="form-label"></label>
                            <input asp-for="EditProduct.Price" class="form-control" min="0" data-product-number-input />
                            <span asp-validation-for="EditProduct.Price" class="text-danger"></span>
                        </div>

                        <div>
                            <label asp-for="EditProduct.StockQty" class="form-label"></label>
                            <input asp-for="EditProduct.StockQty" class="form-control" min="0" data-product-number-input />
                            <span asp-validation-for="EditProduct.StockQty" class="text-danger"></span>
                        </div>

                        <div class="span-2">
                            <label asp-for="EditProduct.CategoryId" class="form-label"></label>
                            <div class="modal-select-wrap">
                                <select asp-for="EditProduct.CategoryId" class="form-select modal-select">
                                    <option value="">Select category</option>
                                    @foreach (var category in Model.AvailableCategories)
                                    {
                                        <option value="@category.Id">@category.Name</option>
                                    }
                                </select>
                            </div>
                            <span asp-validation-for="EditProduct.CategoryId" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="modal-footer user-modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" @(hasCategories ? null : "disabled")>Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteProductModal" tabindex="-1" aria-labelledby="deleteProductModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content user-modal">
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Page" value="@Model.Query.Page" />
                <input type="hidden" name="PageSize" value="@Model.Query.PageSize" />
                <input type="hidden" name="SearchTerm" value="@Model.Query.SearchTerm" />
                <input type="hidden" name="id" id="deleteProductId" />

                <div class="modal-header user-modal-header">
                    <div>
                        <h3 class="modal-title" id="deleteProductModalLabel">Delete Product</h3>
                        <p class="user-modal-subtitle">This action cannot be undone.</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body user-modal-body">
                    <p class="delete-confirmation-copy">
                        Are you sure you want to delete <strong id="deleteProductName">this product</strong>?
                    </p>
                </div>

                <div class="modal-footer user-modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">No</button>
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const createModalElement = document.getElementById('createProductModal');
            const editModalElement = document.getElementById('editProductModal');
            const deleteModalElement = document.getElementById('deleteProductModal');
            const createForm = createModalElement?.querySelector('form') ?? null;
            const editForm = editModalElement?.querySelector('form') ?? null;
            const deleteProductId = document.getElementById('deleteProductId');
            const deleteProductName = document.getElementById('deleteProductName');
            const getProductUrl = '@Url.Action("GetById", "Products")';
            const activeModal = '@Model.ActiveModal';
            const pageSizeSelect = document.getElementById('products-page-size');
            const searchForm = document.querySelector('.users-search-form');
            const searchInput = document.getElementById('products-table-search');
            const numberInputs = document.querySelectorAll('[data-product-number-input]');
            const modalElements = [createModalElement, editModalElement, deleteModalElement].filter(Boolean);
            let keepCreateValidationOnFirstShow = activeModal === 'create';
            let keepEditValidationOnFirstShow = activeModal === 'edit';
            let preserveEditValuesOnNextShow = false;
            let searchDebounceId = 0;

            modalElements.forEach(modalElement => {
                if (modalElement.parentElement !== document.body) {
                    document.body.appendChild(modalElement);
                }
            });

            const clearValidationState = form => {
                if (!form) {
                    return;
                }

                if (window.jQuery) {
                    const formValidator = window.jQuery(form).data('validator');
                    formValidator?.resetForm();
                }

                form.querySelectorAll('.input-validation-error, .is-invalid').forEach(element => {
                    element.classList.remove('input-validation-error', 'is-invalid');
                    element.removeAttribute('aria-invalid');
                });

                form.querySelectorAll('.field-validation-error').forEach(element => {
                    element.classList.remove('field-validation-error');
                    element.classList.add('field-validation-valid');
                    element.innerHTML = '';
                });

                form.querySelectorAll('.validation-summary-errors').forEach(element => {
                    element.classList.remove('validation-summary-errors');
                    element.classList.add('validation-summary-valid');
                    const summaryList = element.querySelector('ul') ?? document.createElement('ul');
                    summaryList.innerHTML = '';

                    if (!element.contains(summaryList)) {
                        element.appendChild(summaryList);
                    }
                });
            };

            const resetCreateFormFields = form => {
                if (!form) {
                    return;
                }

                form.querySelectorAll('input:not([type="hidden"]):not([type="checkbox"]):not([type="radio"])').forEach(input => {
                    if (input.type === 'number') {
                        input.value = '0';
                        return;
                    }

                    input.value = '';
                });

                const categorySelect = form.querySelector('select[name="CreateProduct.CategoryId"]');
                const isActiveInput = form.querySelector('input[name="CreateProduct.IsActive"]');

                if (categorySelect) {
                    categorySelect.value = '';
                }

                if (isActiveInput) {
                    isActiveInput.value = 'true';
                }
            };

            const resetEditFormFields = form => {
                if (!form) {
                    return;
                }

                const idInput = form.querySelector('input[name="EditProduct.Id"]');
                const nameInput = form.querySelector('input[name="EditProduct.Name"]');
                const priceInput = form.querySelector('input[name="EditProduct.Price"]');
                const stockInput = form.querySelector('input[name="EditProduct.StockQty"]');
                const categorySelect = form.querySelector('select[name="EditProduct.CategoryId"]');
                const isActiveInput = form.querySelector('input[name="EditProduct.IsActive"]');

                if (idInput) {
                    idInput.value = '';
                }

                if (nameInput) {
                    nameInput.value = '';
                }

                if (priceInput) {
                    priceInput.value = '0';
                }

                if (stockInput) {
                    stockInput.value = '0';
                }

                if (categorySelect) {
                    categorySelect.value = '';
                }

                if (isActiveInput) {
                    isActiveInput.value = 'true';
                }
            };

            const resetModalState = (form, resetFields) => {
                clearValidationState(form);
                resetFields?.(form);
            };

            const selectInputValue = input => {
                window.requestAnimationFrame(() => {
                    input.select?.();
                });
            };

            numberInputs.forEach(input => {
                input.addEventListener('focus', () => {
                    selectInputValue(input);
                });

                input.addEventListener('pointerdown', event => {
                    if (document.activeElement !== input) {
                        event.preventDefault();
                        input.focus();
                        return;
                    }

                    selectInputValue(input);
                });
            });

            const registerDismissReset = (modalElement, form, resetFields) => {
                if (!modalElement || !form) {
                    return;
                }

                modalElement.addEventListener('hide.bs.modal', () => {
                    resetModalState(form, resetFields);
                });

                modalElement.querySelectorAll('[data-bs-dismiss="modal"]').forEach(button => {
                    button.addEventListener('click', () => {
                        resetModalState(form, resetFields);
                    });
                });
            };

            registerDismissReset(createModalElement, createForm, resetCreateFormFields);
            registerDismissReset(editModalElement, editForm, resetEditFormFields);

            createModalElement?.addEventListener('hidden.bs.modal', () => {
                resetModalState(createForm, resetCreateFormFields);
            });

            editModalElement?.addEventListener('hidden.bs.modal', () => {
                resetModalState(editForm, resetEditFormFields);
            });

            createModalElement?.addEventListener('show.bs.modal', () => {
                if (keepCreateValidationOnFirstShow) {
                    keepCreateValidationOnFirstShow = false;
                    return;
                }

                resetModalState(createForm, resetCreateFormFields);
            });

            editModalElement?.addEventListener('show.bs.modal', () => {
                if (keepEditValidationOnFirstShow || preserveEditValuesOnNextShow) {
                    keepEditValidationOnFirstShow = false;
                    preserveEditValuesOnNextShow = false;
                    return;
                }

                resetModalState(editForm, resetEditFormFields);
            });

            document.querySelectorAll('[data-product-edit]').forEach(button => {
                button.addEventListener('click', async () => {
                    const productId = button.getAttribute('data-product-id');

                    if (!productId || !editModalElement) {
                        return;
                    }

                    try {
                        const response = await fetch(`${getProductUrl}?id=${encodeURIComponent(productId)}`, {
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        });

                        if (!response.ok) {
                            throw new Error('Unable to load product details.');
                        }

                        const product = await response.json();
                        resetModalState(editForm, resetEditFormFields);
                        document.getElementById('EditProduct_Id').value = product.id ?? '';
                        document.getElementById('EditProduct_Name').value = product.name ?? '';
                        document.getElementById('EditProduct_Price').value = product.price ?? 0;
                        document.getElementById('EditProduct_StockQty').value = product.stockQty ?? 0;
                        document.getElementById('EditProduct_CategoryId').value = product.categoryId ?? '';

                        preserveEditValuesOnNextShow = true;
                        bootstrap.Modal.getOrCreateInstance(editModalElement).show();
                    } catch (error) {
                        window.alert('Unable to load the selected product.');
                    }
                });
            });

            document.querySelectorAll('[data-product-delete]').forEach(button => {
                button.addEventListener('click', () => {
                    if (!deleteModalElement || !deleteProductId || !deleteProductName) {
                        return;
                    }

                    deleteProductId.value = button.getAttribute('data-product-id') ?? '';
                    deleteProductName.textContent = button.getAttribute('data-product-name') ?? 'this product';
                    bootstrap.Modal.getOrCreateInstance(deleteModalElement).show();
                });
            });

            if (activeModal === 'create' && createModalElement) {
                bootstrap.Modal.getOrCreateInstance(createModalElement).show();
            }

            if (activeModal === 'edit' && editModalElement) {
                bootstrap.Modal.getOrCreateInstance(editModalElement).show();
            }

            pageSizeSelect?.addEventListener('change', () => {
                pageSizeSelect.form?.submit();
            });

            searchInput?.addEventListener('input', () => {
                window.clearTimeout(searchDebounceId);
                searchDebounceId = window.setTimeout(() => {
                    searchForm?.requestSubmit();
                }, 350);
            });

            searchInput?.addEventListener('keydown', event => {
                if (event.key !== 'Enter') {
                    return;
                }

                event.preventDefault();
                window.clearTimeout(searchDebounceId);
                searchForm?.requestSubmit();
            });

            searchInput?.addEventListener('search', () => {
                window.clearTimeout(searchDebounceId);
                searchForm?.requestSubmit();
            });
        })();
    </script>
}
